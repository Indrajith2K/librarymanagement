
{
    "entities": {
        "Book": {
            "title": "Book",
            "description": "Represents a book title in the library's collection, with quantities for stock management.",
            "type": "object",
            "properties": {
                "title": { "type": "string", "description": "The title of the book." },
                "author": { "type": "string", "description": "The author of the book." },
                "category": { "type": "string", "description": "The genre or category of the book." },
                "quantityTotal": { "type": "number", "description": "The total number of copies of this book in stock." },
                "quantityIssued": { "type": "number", "description": "The number of copies currently issued to members." },
                "createdAt": { "type": "string", "format": "date-time" },
                "updatedAt": { "type": "string", "format": "date-time" }
            },
            "required": ["title", "author", "category", "quantityTotal", "quantityIssued"]
        },
        "Member": {
            "title": "Member",
            "description": "Represents a student or staff member who can borrow books.",
            "type": "object",
            "properties": {
                "name": { "type": "string", "description": "The full name of the member." },
                "memberType": { "type": "string", "enum": ["student", "staff"] },
                "email": { "type": "string", "format": "email" },
                "rfidCardId": { "type": "string", "description": "The ID of the RFID card assigned to this member. Used for login simulation." },
                "isActive": { "type": "boolean", "description": "Whether the member's account is active." },
                "createdAt": { "type": "string", "format": "date-time" },
                "updatedAt": { "type": "string", "format": "date-time" }
            },
            "required": ["name", "memberType", "email", "isActive", "rfidCardId"]
        },
        "CirculationLog": {
            "title": "Circulation Log",
            "description": "A log entry for a circulation event (issue or return).",
            "type": "object",
            "properties": {
                "bookId": { "type": "string" },
                "memberId": { "type": "string" },
                "action": { "type": "string", "enum": ["issue", "return"] },
                "status": { "type": "string", "enum": ["issued", "returned", "overdue"] },
                "issuedAt": { "type": "string", "format": "date-time" },
                "dueDate": { "type": "string", "format": "date-time" },
                "returnedAt": { "type": "string", "format": "date-time" },
                "actorId": { "type": "string", "description": "The UID of the admin or member who performed the action." }
            },
            "required": ["bookId", "memberId", "action", "actorId", "issuedAt", "status"]
        },
        "AdminUser": {
            "title": "Admin User",
            "description": "An administrator or staff account with specific roles.",
            "type": "object",
            "properties": {
                "uid": { "type": "string", "description": "Matches Firebase Auth UID for users logging in with Google." },
                "email": { "type": "string", "format": "email", "description": "Email of the admin user." },
                "role": { "type": "string", "enum": ["Super Admin", "Librarian", "Assistant", "Logger"] },
                "displayName": { "type": "string" },
                "staffId": { "type": "string", "description": "Unique Staff ID for password-based login." },
                "password": { "type": "string", "description": "Plaintext password for demonstration." },
                "photoURL": { "type": "string", "format": "uri" }
            },
            "required": ["role"]
        }
    },
    "auth": {
        "providers": ["password", "google.com"]
    },
    "firestore": {
        "/books/{bookId}": { "schema": { "$ref": "#/entities/Book" }, "description": "Collection of all book titles." },
        "/members/{memberId}": { "schema": { "$ref": "#/entities/Member" }, "description": "Collection of all library members." },
        "/circulationLogs/{logId}": { "schema": { "$ref": "#/entities/CirculationLog" }, "description": "Logs of all circulation events." },
        "/adminusers/{userId}": { "schema": { "$ref": "#/entities/AdminUser" }, "description": "Administrator and staff accounts." }
    }
}
