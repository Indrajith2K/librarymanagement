
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Gets the role of the currently authenticated user from the 'adminusers' collection.
    // This supports both Google Auth (via UID) and Password Auth (via staffId in resource).
    function getRole(uid) {
      return get(/databases/$(database)/documents/adminusers/$(uid)).data.role;
    }

    function isSuperAdmin() {
      // For Google-authenticated users, we can check if their UID exists in the adminusers collection.
      return isSignedIn() && getRole(request.auth.uid) == 'Super Admin';
    }

    function isLibrarian() {
       return isSignedIn() && getRole(request.auth.uid) in ['Super Admin', 'Librarian'];
    }

    // This function allows read access to any authenticated user who exists in the adminusers collection.
    // This is the base permission for all admin roles, including read-only 'Logger'.
    function isAnyAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminusers/$(request.auth.uid));
    }


    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /books/{bookId} {
      allow read: if true; // Allow public read for main user flows
      allow write: if isLibrarian(); // Allow create, update, delete only for Librarians and Super Admins
    }

    match /members/{memberId} {
      allow read: if isAnyAdmin();
      allow write: if isLibrarian();
    }
    
    match /adminusers/{userId} {
      // Any admin can read the list of other admins
      allow read: if isAnyAdmin();
      // Only Super Admins can create, update, or delete other admin users
      allow write: if isSuperAdmin();
    }

    // Read-only collections for Loggers, Assistants
    match /circulationLogs/{logId} {
      allow read: if isAnyAdmin();
      allow write: if isLibrarian();
    }

    match /rfidTags/{rfidTagId} {
      allow read: if isAnyAdmin();
      allow write: if isLibrarian();
    }

    match /inventoryScans/{inventoryScanId} {
      allow read: if isAnyAdmin();
      allow write: if isLibrarian();
    }

    match /securityAlerts/{alertId} {
      allow read: if isAnyAdmin();
      allow write: if isLibrarian();
    }

    match /reservations/{reservationId} {
      allow read: if isAnyAdmin();
      allow write: if isLibrarian();
    }

    match /fines/{fineId} {
      allow read: if isAnyAdmin();
      allow write: if isLibrarian();
    }

    match /reports/{reportId} {
      allow read: if isAnyAdmin();
      allow create: if isLibrarian();
      allow update, delete: if isSuperAdmin();
    }

    match /systemSettings/{systemSettingId} {
      allow read: if isAnyAdmin();
      allow write: if isSuperAdmin();
    }

    match /adminActivityLogs/{adminActivityLogId} {
      allow read: if isAnyAdmin();
      allow create: if isLibrarian();
      allow update, delete: if false;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    match /profile-pictures/{adminUserDocId} {
      allow read: if true;
      allow write: if request.resource.metadata.uid == adminUserDocId;
    }
  }
}
