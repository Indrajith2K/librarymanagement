
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Gets the role of the currently authenticated user from the 'adminusers' collection.
    // This is secure because it's a server-side read.
    function getRole(uid) {
      let userDoc = get(/databases/$(database)/documents/adminusers/$(uid));
      // Handle password-based legacy user that might not exist in auth
      if (!exists(/databases/$(database)/documents/adminusers/$(uid))) {
          // This part is tricky. For non-auth users, we can't reliably get a role here.
          // The application logic MUST handle session management securely.
          // We will deny by default if no user doc is found.
          return 'NoRole';
      }
      return userDoc.data.role;
    }
    
    // Checks if the user has a valid document in the adminusers collection.
    // This covers password-based users where `request.auth` is null but they have a session.
    // NOTE: This rule relies on the app to securely validate password users and not let just anyone query.
    // The `isAnyAdmin()` function below is what we should use for general read access.
    function isKnownAdmin() {
      // This part is for Google-authenticated users
      if (isSignedIn()) {
        return exists(/databases/$(database)/documents/adminusers/$(request.auth.uid));
      }
      // This is a placeholder for password-based logic. 
      // For truly secure password-based auth, you'd use custom tokens.
      // Since we are using a simple password check in the app, our rules here are limited.
      // We will rely on app-level checks for password users and grant broad access here,
      // which is NOT recommended for production.
      return true; // DANGEROUS: Temporarily allowing for password-based users.
    }


    // Checks if the authenticated user is a Super Admin.
    function isSuperAdmin() {
      return isSignedIn() && getRole(request.auth.uid) == 'Super Admin';
    }

    // Checks if the authenticated user is a Super Admin or a Librarian.
    function isLibrarian() {
       return isSignedIn() && getRole(request.auth.uid) in ['Super Admin', 'Librarian'];
    }

    // This function allows read access to any authenticated user who has a document in the adminusers collection.
    // This covers all roles: Super Admin, Librarian, Assistant, and Logger.
    function isAnyAdmin() {
      if (isSignedIn()) {
        return exists(/databases/$(database)/documents/adminusers/$(request.auth.uid));
      }
      // This covers the password-based user case. `isKnownAdmin()` is too permissive.
      // We assume if they're not a Google-signed-in user, they're a password user.
      // This is not perfectly secure but matches the app's current logic.
      return true;
    }


    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /books/{bookId} {
      // Any admin role can read book data.
      allow read: if isAnyAdmin(); 
      // Only Super Admins and Librarians can create, update, or delete books.
      allow write: if isLibrarian();
    }

    match /members/{memberId} {
      // Any admin role can read member data.
      allow read: if isAnyAdmin();
      // Only Super Admins and Librarians can create, update, or delete members.
      allow write: if isLibrarian();
    }
    
    match /adminusers/{userId} {
      // Any admin can read the user list to populate the UI.
      allow read: if isAnyAdmin();
      // ONLY a Super Admin can create, update, or delete other user records.
      allow write: if isSuperAdmin();
    }

    // Fallback rule for any other collections that might be created in the future.
    // By default, deny all access unless explicitly allowed by more specific rules.
    match /{path=**}/documents/{document} {
      allow read, write: if false;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // This rule allows any authenticated user to upload a profile picture for themselves.
    // It checks if the UID in the auth token matches the document ID they are trying to write to.
    match /profile-pictures/{adminUserDocId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == adminUserDocId;
    }
  }
}
