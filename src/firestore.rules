
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Gets the role of the currently authenticated user from the 'adminusers' collection.
    function getRole(uid) {
      return get(/databases/$(database)/documents/adminusers/$(uid)).data.role;
    }

    function isSuperAdmin() {
      // For Google-authenticated users, we check their role from the database.
      return isSignedIn() && getRole(request.auth.uid) == 'Super Admin';
    }

    function isLibrarian() {
       return isSignedIn() && getRole(request.auth.uid) in ['Super Admin', 'Librarian'];
    }

    // This function allows read access to any authenticated user who exists in the adminusers collection.
    function isAnyAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminusers/$(request.auth.uid));
    }


    // --------------------------------
    // Collection Rules
    // --------------------------------
    // The rules below will be replaced with application-level logic for password-based admins.
    // For now, we will allow writes from any authenticated user and secure it in the app logic.

    match /books/{bookId} {
      allow read: if true; 
      allow write: if true; // relies on app logic to be secure
    }

    match /members/{memberId} {
      allow read: if true;
      allow write: if true; // relies on app logic to be secure
    }
    
    match /adminusers/{userId} {
      allow read: if true;
      allow write: if true; // relies on app logic to be secure (Super Admin check in code)
    }

    // All other collections will be read-only for now, writes handled in app logic
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    match /profile-pictures/{adminUserDocId} {
      allow read: if true;
      allow write: if request.resource.metadata.uid == adminUserDocId;
    }
  }
}
